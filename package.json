{
  "name": "@loopworx/forge",
  "version": "0.2.0",
  "description": "AI-driven software delivery orchestrator that coordinates seven specialized AI agents through a lean delivery pipeline",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/loopworx/forge.git"
  },
  "homepage": "https://github.com/loopworx/forge",
  "bugs": {
    "url": "https://github.com/loopworx/forge/issues"
  },
  "keywords": [
    "ai-agents",
    "delivery",
    "linear",
    "pi-dev",
    "atdd",
    "tdd",
    "lean",
    "xp",
    "ci-cd"
  ],
  "main": "dist/forge.js",
  "bin": {
    "forge": "./dist/forge.js"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/ tests/",
    "init": "bun run bin/forge.ts init",
    "prepublishOnly": "bun run typecheck && bun test && bun run build"
  },
  "files": [
    "dist/",
    "templates/",
    "tsconfig.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "open": "^11.0.0",
    "yaml": "^2.9.0"
  },
  "peerDependencies": {},
  "devDependencies": {
    "@types/bun": "latest",
    "oxlint": "^1.72.0",
    "typescript": "^5.9.3"
  }
}
